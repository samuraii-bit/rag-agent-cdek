# =============================================================================
# CdekStart RAG agent — конфигурация (необязательная)
#
# Этот файл НЕ нужен для запуска! По умолчанию проект работает на
# локальной Ollama + Qwen2.5:3b и стартует одной командой:
#     docker-compose up --build
#
# Скопируйте файл в .env, только если хотите переопределить значения,
# например — переключиться на OpenAI для более высокого качества.
#     cp .env.example .env
# =============================================================================

# ---- LLM провайдер -----------------------------------------------------------
# По умолчанию: ollama (Qwen2.5:3b, полностью локально, без ключей).
# Поддерживаемые значения: ollama | openai | anthropic
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:3b
LLM_TEMPERATURE=0.0

# Чтобы использовать OpenAI gpt-4o-mini (выше качество ответов на сложных
# формулировках), раскомментируйте и заполните:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-haiku-20241022
# ANTHROPIC_API_KEY=sk-ant-...

# ---- Embeddings (locally cached sentence-transformers) ----------------------
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ---- Retrieval ---------------------------------------------------------------
RETRIEVAL_TOP_K=4

# ---- API ---------------------------------------------------------------------
API_PORT=8000
LOG_LEVEL=INFO
